# =============================================================================
# Oracle Intelligence Platform — Environment Variables
# =============================================================================
# 1. Copy this file:  cp .env.example oracle_intent_engine/.env
#                     cp .env.example lead_enrichment_engine/.env
# 2. Fill in your values below
# 3. NEVER commit .env files to git (already in .gitignore)
# =============================================================================

# ── PostgreSQL (Oracle Intent DB) ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oracle_intent
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_64_char_hex_secret_here

# ── Apollo.io ─────────────────────────────────────────────────────────────────
# Get from: app.apollo.io → Settings → Integrations → API
APOLLO_API_KEY=your_apollo_api_key_here

# ── ZeroBounce Email Validation ───────────────────────────────────────────────
# Get from: app.zerobounce.net → API → API Key
ZEROBOUNCE_API_KEY=your_zerobounce_api_key_here

# ── HubSpot CRM ───────────────────────────────────────────────────────────────
# Get from: app.hubspot.com → Settings → Integrations → Private Apps
HUBSPOT_API_KEY=your_hubspot_private_app_token_here

# ── Apify (LinkedIn scraping — optional) ─────────────────────────────────────
# Get from: console.apify.com → Settings → Integrations
APIFY_TOKEN=your_apify_token_here
APIFY_LINKEDIN_ACTOR_ID=anchor/linkedin-people-finder
APIFY_EMAIL_ACTOR_ID=blitzapi/linkedin-email-finder

# ── Master Contact Database ───────────────────────────────────────────────────
# Format: postgresql://user:password@host:5432/dbname
PG_MASTER_CONNECTION_STRING=postgresql://postgres:your_password@localhost:5432/oracle_intent
PG_CONNECTION_STRING=
PG_INPUT_TABLE=leads
PG_OUTPUT_TABLE=enriched_leads
