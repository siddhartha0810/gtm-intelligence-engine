# ── Lead Enrichment Engine — API Keys ─────────────────────────────────────
# Copy this file to .env and fill in your keys. Never commit .env to git.

# Apollo.io — finds emails + LinkedIn URLs from name + company + domain
# Get from: app.apollo.io → Settings → Integrations → API
# Auth method: X-Api-Key header (NOT Authorization: Bearer)
APOLLO_API_KEY=your_apollo_key_here

# ZeroBounce — validates whether email addresses actually exist
# Get from: app.zerobounce.net → API → API Key
# Each email validation uses 1 credit
ZEROBOUNCE_API_KEY=your_zerobounce_key_here

# Apify — fallback enrichment via LinkedIn scraping (optional)
# Get token from: console.apify.com → Settings → Integrations
# Leave actor IDs blank to skip Apify entirely
APIFY_TOKEN=your_apify_token_here

# Phase 1 — finds LinkedIn URL from name + company
# Recommended actor: anchor/linkedin-people-finder
APIFY_LINKEDIN_ACTOR_ID=

# Phase 2 — finds work email from LinkedIn URL
# Recommended actor: blitzapi/linkedin-email-finder
APIFY_EMAIL_ACTOR_ID=

# ZoomInfo — optional premium enrichment (disabled by default)
# Only used if you add "zoominfo" to DOMAIN_OVERRIDES in orchestrator.py
ZOOMINFO_API_KEY=
ZOOMINFO_BASE_URL=https://api.zoominfo.com

# ── PostgreSQL master store ────────────────────────────────────────────────
# All enriched leads accumulate here across every pipeline run.
# Format: postgresql://user:password@host:5432/dbname
DB_HOST=10.0.0.149
DB_PORT=5432
DB_NAME=oracle_intent
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

PG_MASTER_CONNECTION_STRING=postgresql://postgres:your_password@10.0.0.149:5432/oracle_intent

# Optional separate pipeline input/output tables
PG_CONNECTION_STRING=
PG_INPUT_TABLE=leads
PG_OUTPUT_TABLE=enriched_leads
