# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oracle_intent
DB_USER=postgres
DB_PASSWORD=your_password

# Optional API keys (enhances signal quality if provided)
NEWSAPI_KEY=
SERPAPI_KEY=
BING_NEWS_KEY=

# Scraping behavior
SCAN_DELAY_MIN=2
SCAN_DELAY_MAX=6
MAX_PAGES=3

# Flask
FLASK_SECRET_KEY=change_this_secret
FLASK_PORT=5001
