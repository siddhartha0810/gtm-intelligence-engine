# Oracle Intent Engine â€” Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# PostgreSQL — must be on office network or VPN to reach 10.0.0.149
DB_HOST=10.0.0.149
DB_PORT=5432
DB_NAME=Inoapps-Data-DB
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# JWT Authentication (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=your_64_char_hex_secret_here

# Apollo.io API
APOLLO_API_KEY=your_apollo_api_key_here

# ZeroBounce Email Validation
ZEROBOUNCE_API_KEY=your_zerobounce_api_key_here

# Apify (LinkedIn scraping)
APIFY_TOKEN=your_apify_token_here
APIFY_LINKEDIN_ACTOR_ID=your_actor_id_here
APIFY_EMAIL_ACTOR_ID=your_email_actor_id_here

# HubSpot CRM
HUBSPOT_API_KEY=your_hubspot_api_key_here

# Optional
FLASK_PORT=5001
